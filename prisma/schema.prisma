generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Event {
  id            String         @id @default(dbgenerated("concat('event', lpad((nextval('events_id_seq'::regclass))::text, 6, '0'::text))"))
  date          DateTime
  timezone      String?        @default("America/Chicago")
  speaker       String
  affiliation   String
  talkTitle     String
  type          String
  recordingUrl  String?
  zoomUrl       String?
  isUpcoming    Boolean        @default(false)
  description   String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  registrations Registration[]

  @@map("events")
}

model Registration {
  id          String   @id @default(cuid())
  eventId     String
  fullName    String
  email       String
  affiliation String
  position    String
  createdAt   DateTime @default(now())
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("registrations")
}

model Member {
  id           String   @id @default(dbgenerated("concat('mem', lpad((nextval('members_id_seq'::regclass))::text, 6, '0'::text))"))
  fullName     String
  position     String
  affiliation  String
  email        String   @unique
  phone        String?
  country      String
  state        String
  expertise    String
  status       String
  mentoring    String
  volunteering String
  shareName    String
  createdAt    DateTime @default(now())

  @@map("members")
}

